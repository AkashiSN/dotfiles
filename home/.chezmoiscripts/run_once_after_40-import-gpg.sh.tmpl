#!/bin/sh
# Import the GPG key and write gpg-agent.conf (SSH support via gpg-agent).
set -eu

export PATH="/usr/local/MacGPG2/bin:/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

if ! gpg --list-keys nishi >/dev/null 2>&1; then
	gpg --import "${CHEZMOI_WORKING_TREE}/gpg/nishi.gpg"
	printf '5\ny\n' | gpg --command-fd 0 --edit-key nishi trust
fi

homedir="$(gpgconf --list-dir homedir)"
if [ ! -f "$homedir/gpg-agent.conf" ]; then
{{- if eq .chezmoi.os "darwin" }}
	echo "pinentry-program  /usr/local/MacGPG2/libexec/pinentry-mac.app/Contents/MacOS/pinentry-mac" > "$homedir/gpg-agent.conf"
{{- else }}
	if uname -r | grep -qi microsoft; then
		echo "pinentry-program  /usr/bin/pinentry-curses" > "$homedir/gpg-agent.conf"
	fi
{{- end }}
	cat >> "$homedir/gpg-agent.conf" <<'EOF'

enable-ssh-support
default-cache-ttl-ssh    7200
max-cache-ttl-ssh       28800
EOF
fi
