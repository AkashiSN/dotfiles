#!/usr/bin/env python3
"""portfwd - SSH 先のブラウザ起動をローカルへ転送するローカル daemon.

リモートの portfwd-open シムが RemoteForward 経由で 127.0.0.1:55999 へ
{"host","url"} を POST する。daemon は url の callback ポートを ControlMaster へ
-L フォワードし、ローカルのブラウザを開く。

サブコマンド:
  serve   : 55999 で listen する常駐ループ（フォアグラウンド）
  ensure  : 未起動なら serve をバックグラウンド起動（冪等。ssh LocalCommand 用）
  stop    : pidfile の daemon を停止
  status  : 稼働状況を表示
"""
import json
import os
import re
import signal
import socket
import subprocess
import sys
import threading
import time
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path
from urllib.parse import urlparse, parse_qs

PORT = int(os.environ.get("PORTFWD_PORT", "55999"))
SSH_DIR = Path(os.environ.get("PORTFWD_SSH_DIR", str(Path.home() / ".ssh")))
PIDFILE = SSH_DIR / "portfwd.pid"
OPEN_CMD = os.environ.get("PORTFWD_OPEN_CMD", "open")
SSH_CMD = os.environ.get("PORTFWD_SSH_CMD", "ssh")
IDLE_SEC = int(os.environ.get("PORTFWD_IDLE_SEC", "1800"))

_last_activity = time.monotonic()


def _log(msg):
    print(f"portfwd: {msg}", file=sys.stderr, flush=True)


def _callback_endpoint(parsed):
    """ブラウザ URL から、ローカルへ -L 転送すべき callback (host, port) を決める。

    2 パターンに対応する:
      1. OAuth/OIDC の authorize URL（例: `aws login` / `gh auth`）。ブラウザが開くのは
         認可サーバ上の URL で、コールバックは `redirect_uri` クエリに localhost:port
         として埋め込まれる（URL 自身のホストは認可サーバなので localhost ではない）。
      2. URL 自体が localhost:port のコールバック（ツールが直接ローカル URL を開く場合）。
    どちらでもないときは (None, None) を返す（呼び出し側は転送せず、URL を開くだけにする）。
    """
    # 1) authorize URL: redirect_uri クエリのローカルコールバックを最優先で使う。
    redirect = parse_qs(parsed.query).get("redirect_uri", [None])[0]
    if redirect:
        r = urlparse(redirect)
        if r.hostname in ("127.0.0.1", "localhost") and r.port:
            return r.hostname, r.port
    # 2) URL 自体がローカルコールバックのとき。
    if parsed.hostname in ("127.0.0.1", "localhost") and parsed.port:
        return parsed.hostname, parsed.port
    return None, None


def handle_notification(payload: dict) -> str:
    """1 通知を処理し、結果メッセージを返す。例外は投げず "ok:" / "reject:" / "error:"
    で始まる文字列で返す（do_POST が prefix で HTTP ステータスを決める）。"""
    host = payload.get("host")
    url = payload.get("url")
    if not host or not url:
        return "reject: host/url がありません"
    try:
        if not re.fullmatch(r'[A-Za-z0-9._-]+', host):
            return f"reject: 不正な host ({host})"
        parsed = urlparse(url)
        # http/https のみ開く（file:// や javascript: などの踏み台化を防ぐ）。
        if parsed.scheme not in ("http", "https"):
            return f"reject: 非対応スキーム ({parsed.scheme or 'なし'})"
        control = SSH_DIR / f"cm-{host}"
        if not control.exists():
            return f"reject: control socket がありません ({control})"
        # localhost callback を伴う URL（OAuth の authorize URL 等）のときだけ、その callback
        # ポートを -L で転送する。普通の URL（callback 無し）は転送せず、ローカルで開くだけ
        # （任意ポート転送は callback がある時のみ＝踏み台化を防ぐ）。
        _, cb_port = _callback_endpoint(parsed)
        fwd = None
        if cb_port:
            fwd = f"{cb_port}:127.0.0.1:{cb_port}"
            # -L を張る（既存なら ssh 側がエラー→握りつぶす）。
            subprocess.run(
                [SSH_CMD, "-O", "forward", "-L", fwd, "-S", str(control), host],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
        # ローカルブラウザで開く（authorize URL なら認可ページ、普通の URL ならそのページ）。
        subprocess.run([OPEN_CMD, url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return f"ok: {('-L ' + fwd + ' ') if fwd else ''}via {host}, opened {url}"
    except Exception as e:
        return f"error: {e}"


class Handler(BaseHTTPRequestHandler):
    def do_POST(self):
        global _last_activity
        _last_activity = time.monotonic()
        length = int(self.headers.get("Content-Length", 0))
        raw = self.rfile.read(length) if length else b""
        try:
            payload = json.loads(raw.decode() or "{}")
        except json.JSONDecodeError:
            self.send_response(400)
            self.end_headers()
            return
        result = handle_notification(payload)
        _log(result)
        # ok のみ 200。reject/error は 4xx で返し、portfwd-open の `curl -f` を失敗させて
        # 呼び出し側（aws login 等）を従来動作（--remote 等）へフォールバックさせる。
        self.send_response(200 if result.startswith("ok:") else 422)
        self.end_headers()
        self.wfile.write(result.encode())

    def log_message(self, *_):  # アクセスログ抑制
        pass


def _should_keep_alive() -> bool:
    """portfwd 対象ホストへの ControlMaster が1つでも生きていれば True。

    対象ホスト（ssh config の `Tag portfwd`）は `ControlPath ~/.ssh/cm-%n` を使うため、
    cm-* socket の存在が「逆チャネルを必要とする SSH セッションが生きている」ことを表す。
    daemon はそれらセッションのために存在するので、生きている間は idle でも終了させない。
    （終了すると RemoteForward のリスナーは accept するのに転送先が居ず、リモートの
    portfwd-open が Connection reset で失敗する。）
    """
    return any(SSH_DIR.glob("cm-*"))


def _idle_watch(httpd):
    global _last_activity
    while True:
        time.sleep(30)
        # 対象 SSH セッションが生きている間は延命する（idle でも殺さない）。
        if _should_keep_alive():
            _last_activity = time.monotonic()
            continue
        # 対象 SSH が全て切れてから IDLE_SEC 経過したらゾンビ回収のため終了する。
        if time.monotonic() - _last_activity > IDLE_SEC:
            _log(f"SSH セッション無し + アイドル {IDLE_SEC}s 超過、終了します")
            httpd.shutdown()
            return


def cmd_serve():
    try:
        httpd = HTTPServer(("127.0.0.1", PORT), Handler)
    except OSError as e:
        _log(f"listen 失敗 ({PORT}): {e}")
        sys.exit(1)
    SSH_DIR.mkdir(parents=True, exist_ok=True)
    PIDFILE.write_text(str(os.getpid()))
    _log(f"listen 127.0.0.1:{PORT} (pid {os.getpid()})")
    threading.Thread(target=_idle_watch, args=(httpd,), daemon=True).start()
    try:
        httpd.serve_forever()
    finally:
        try:
            if PIDFILE.read_text().strip() == str(os.getpid()):
                PIDFILE.unlink()
        except (FileNotFoundError, ValueError):
            pass


def _running_pid():
    try:
        pid = int(PIDFILE.read_text().strip())
    except (FileNotFoundError, ValueError):
        return None
    try:
        os.kill(pid, 0)
    except OSError:
        return None
    # ポートが実際に開いているかも確認。
    with socket.socket() as s:
        s.settimeout(0.3)
        if s.connect_ex(("127.0.0.1", PORT)) != 0:
            return None
    return pid


def cmd_ensure():
    if _running_pid():
        return
    # 自分自身を serve でバックグラウンド起動（多重起動は listen 失敗で自然に排他）。
    subprocess.Popen(
        [sys.executable, os.path.abspath(__file__), "serve"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL, start_new_session=True,
    )


def cmd_stop():
    pid = _running_pid()
    if not pid:
        _log("起動していません")
        return
    try:
        os.kill(pid, signal.SIGTERM)
        _log(f"停止しました (pid {pid})")
    except OSError:
        _log("既に停止済みです")


def cmd_status():
    pid = _running_pid()
    print(f"portfwd: {'running pid '+str(pid) if pid else 'stopped'} (port {PORT})")


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else "status"
    {"serve": cmd_serve, "ensure": cmd_ensure,
     "stop": cmd_stop, "status": cmd_status}.get(cmd, cmd_status)()


if __name__ == "__main__":
    main()
