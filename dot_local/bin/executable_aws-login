#!/bin/bash
# aws-login - aws login ラッパースクリプト（認証本体）
#
# ~/.aws/config の credential_process に登録され、AWS CLI/SDK が認証情報を
# 必要としたときに自動で呼ばれる。aws-switch からも認証の前段として呼ばれる。
# 各プロファイルごとに独立したセッションを管理する。
#
# 使用方法:
#   aws-login <profile_name>
#   - profile_name: ベースプロファイル名（自動的に"-signin"サフィックスが付与されます）
#
# 動作:
#   1. キャッシュから認証情報を取り出し、aws sts get-caller-identity で「実際に通るか」を検証
#      （クレデンシャルが設定されているか、ではなく、いま有効か で判定する）
#   2. 期限切れ／未ログインならブラウザでログインを実行
#   3. STS が到達不能（ネットワーク断等）の一時エラーなら、ログインせずキャッシュで続行
#   4. flockで排他制御し、複数プロセスの同時ログインを防止
#   - get-caller-identity は IAM 権限不要なので、失敗＝トークンが無効/期限切れ を意味する。
#     AWS_LOGIN_SKIP_VERIFY=1 で STS 検証を省略し、従来の「設定があれば OK」動作へ戻せる。
#
# SSH 先での挙動:
#   通常の `aws login` は localhost のコールバックサーバ前提で、SSH 先だとブラウザも
#   開かず localhost に戻ってしまい完結しない。そこで 2 通りに分岐する:
#   - portfwd 逆チャネルが使えるとき（タグ付きホストへの SSH。LC_PORTFWD_HOST がセット
#     済み かつ 127.0.0.1:55999 の portfwd daemon に到達可能）は通常の `aws login` を使う。
#     コールバック URL は $BROWSER=portfwd-open 経由でローカルへ転送され、ローカルの
#     ブラウザが自動で開く（詳細は docs/portfwd-cheatsheet.md）。
#   - 逆チャネルが無い SSH 先では従来どおり `aws login --remote` にフォールバックする。
#     --remote は localhost コールバックを無効化し、URL 表示＋認証コード貼り付け方式に
#     切り替える（公式のリモート用フロー）。
#   どちらも URL/プロンプトは呼び出し元の出力抑制を貫通させるため制御端末（/dev/tty）に
#   直結する。
#
# 注意:
#   - プロファイルごとに異なるキャッシュを持つため、
#     ユーザー権限とAssume Role権限を別々に管理できる
#   - USER_DIR（direnv）でロックファイルを分離し、共有ユーザー環境での競合を防止
#
# 依存:
#   - flock: 多重ログイン防止に使用。aqua には無い。
#            Linux は util-linux 同梱、macOS は Homebrew（brew install flock）で導入する。

set -e

# ロックファイル（.aws/.aws-login-*.lock）の置き場所。共有ユーザー環境では USER_DIR で分離する
USER_DIR=${USER_DIR:-~}

# プロファイル名に"-signin"サフィックスを付与
# 例: "my-profile" → "my-profile-signin"
export AWS_PROFILE="$1-signin"

# EC2インスタンスのメタデータサービスを無効化
# ローカル環境でEC2の認証情報が誤って使用されるのを防ぐ
export AWS_EC2_METADATA_DISABLED=true

# "-signin"プロファイルが存在していない場合
if ! aws configure list-profiles | grep "$AWS_PROFILE" >/dev/null 2>&1; then
    # AWSリージョンを東京に設定
    aws configure set region ap-northeast-1
fi

# キャッシュ済み認証情報が「実際に有効か」を STS で検証するヘルパー。
#   - export-credentials でローカルキャッシュから creds を取り出す（ネットワーク不要）。
#   - 取り出せたら aws sts get-caller-identity で実際に通るかを確認する。
#     credential_process の stdout は creds 出力専用なので STS の出力は捨て、stderr だけを
#     拾ってエラー種別を判定する。AWS_PROFILE は -signin に固定済みで、signin プロファイルは
#     credential_process を持たない（base プロファイルのみが持つ）ため、この STS 呼び出しは
#     aws-login へ戻らず再帰しない。get-caller-identity は IAM 権限不要なので、失敗＝
#     トークンが無効/期限切れ を意味する。
# 戻り値:
#   0 : 有効。creds を stdout に出力済み
#   2 : STS が到達不能（ネットワーク断等）で検証できず。期限内の可能性が高いのでキャッシュ
#       creds を出力済み（ログインはしない＝従来の方針どおり）
#   1 : 未ログイン or 認証切れ。creds 未出力（呼び出し側はログインへ進む）
emit_creds_if_valid() {
    local creds sts_err
    creds=$(aws configure export-credentials --format process 2>/dev/null) || return 1
    [ -n "$creds" ] || return 1
    # 抜け道: 従来どおり「設定があれば OK」に戻す。
    if [ -n "$AWS_LOGIN_SKIP_VERIFY" ]; then
        printf '%s\n' "$creds"
        return 0
    fi
    if sts_err=$(aws sts get-caller-identity 2>&1 >/dev/null); then
        printf '%s\n' "$creds"
        return 0
    fi
    # STS 失敗。到達不能などの一時エラーならログインせずキャッシュで続行する。
    if printf '%s' "$sts_err" | grep -qiE 'could not connect|connect timeout|endpointconnectionerror|failed to establish|name resolution|getaddrinfo|name or service not known|network is unreachable|read timeout|connection (reset|aborted|refused)|temporarily unavailable|service unavailable|timed out'; then
        printf >&2 '%s\n' "aws-login: STS 検証をスキップ（${AWS_PROFILE}: ネットワーク到達不可）。キャッシュ済み認証情報で続行します。"
        printf '%s\n' "$creds"
        return 2
    fi
    # ExpiredToken / InvalidClientTokenId / SSO トークン期限切れ 等 → 認証切れとみなす。
    return 1
}

# portfwd 逆チャネルが使えるか判定する。
#   - LC_PORTFWD_HOST がセット済み（タグ付きホストへの SSH セッション）かつ
#     127.0.0.1:55999 に接続できれば、ローカルの portfwd daemon 経由で
#     ブラウザを開ける。この場合 aws login --remote ではなく通常の
#     aws login（localhost コールバック）を使う。
portfwd_channel_available() {
    [ -n "${LC_PORTFWD_HOST:-}" ] || return 1
    local port="${PORTFWD_PORT:-55999}"
    # bash /dev/tcp で接続確認（2 秒タイムアウト）。
    timeout 2 bash -c "exec 3<>/dev/tcp/127.0.0.1/${port}" 2>/dev/null
}

# 既存セッションが「実際に有効か」を検証し、有効ならその creds を出力して終了する。
# 設定の有無ではなく STS の応答で判定するため、期限切れ/権限喪失はここを通過して
# 下のログインフローへ進む。
rc=0; emit_creds_if_valid || rc=$?
if [ "$rc" -ne 1 ]; then
    exit 0
fi

# 認証情報の取得に失敗 → flockで排他制御してログイン
(
    flock -w 60 200 || exit 1
    # ロック取得後に再チェック（待っている間に別プロセスがログイン済みかもしれない）。
    # ここでも STS で実際に有効かを確認するが、creds の出力は最後の 1 箇所に集約するため
    # ここでは抑制し、判定結果（多重ログイン回避）だけを使う。
    rc=0; emit_creds_if_valid >/dev/null 2>&1 || rc=$?
    if [ "$rc" -ne 1 ]; then
        exit 0
    fi

    # ローカル / portfwd 逆チャネルあり SSH / 逆チャネル無し SSH で認証方式を切り替える
    # （各分岐の詳細はファイル冒頭「SSH 先での挙動」を参照）。
    # portfwd 逆チャネルの判定は 1 回だけ行いキャッシュする（timeout の二重実行を避ける）。
    portfwd_ok=""
    if portfwd_channel_available; then portfwd_ok=1; fi

    if [[ -n $portfwd_ok ]] && { : >/dev/tty; } 2>/dev/null; then
        # 逆チャネルあり＋制御端末あり。通常の aws login（localhost コールバック）を使い、
        # $BROWSER=portfwd-open 経由でローカルブラウザが開く。
        aws login </dev/tty >/dev/tty 2>&1
    elif [[ -n $portfwd_ok ]]; then
        # 逆チャネルありだが制御端末なし。出力は継承 fd のまま通常 aws login。
        aws login
    elif [[ -n $SSH_CONNECTION ]] && { : >/dev/tty; } 2>/dev/null; then
        # SSH だが逆チャネル無し。従来どおり URL 表示＋コード貼り付け。
        aws login --remote </dev/tty >/dev/tty 2>&1
    elif [[ -n $SSH_CONNECTION ]]; then
        aws login --remote
    else
        # ローカル。ブラウザでの認証（従来どおり）。
        unset DISPLAY
        aws login
    fi
) 200>"${USER_DIR}/.aws/.aws-login-${1}.lock"

# ログイン直後（または上のロック内で別プロセスがログイン済みと判明した）creds を出力する。
# 出力をこの 1 箇所に集約しているので、credential_process の stdout に JSON が二重に出ない。
aws configure export-credentials --format process
