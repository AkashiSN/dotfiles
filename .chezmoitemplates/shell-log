# 共通ログ関数（.chezmoitemplates/shell-log から各スクリプトへ注入）。
# 見出しの色・書式はここ 1 箇所で定義し、各スクリプトは step/notice/note を呼ぶだけにする。
step()   { printf '\n\033[1;36m==> %s\033[0m\n' "$1"; }  # cyan "==>": 進行中ステップの見出し
notice() { printf '\n\033[1;33m==> %s\033[0m\n' "$1"; }  # yellow "==>": 完了/案内の見出し
note()   { printf '  \033[1m%s\033[0m\n' "$1"; }         # bold: 見出し配下のサブ項目
