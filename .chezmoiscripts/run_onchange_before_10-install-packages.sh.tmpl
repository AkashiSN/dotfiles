#!/bin/sh
# Provision package prerequisites that must exist before chezmoi applies files
# and before `aqua install` runs. Tools themselves are declared in aqua.yaml.
# run_onchange: 下の formula / cask 一覧を書き換えると既存マシンでも再実行される（brew は冪等）。
set -eu

PREFIX="$HOME/.local"
mkdir -p "$PREFIX/bin" "$PREFIX/lib"

{{ if eq .chezmoi.os "darwin" -}}
# --- macOS: Homebrew (GNU userland + a few system tools not in aqua) ---
if ! command -v brew >/dev/null 2>&1; then
	/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
BREW_PREFIX={{ if eq .chezmoi.arch "arm64" }}/opt/homebrew{{ else }}/usr/local{{ end }}
eval "$($BREW_PREFIX/bin/brew shellenv)"

# Homebrew formula（aqua に無いシステムツール / GNU userland）。
# 用途ごとにグループ分け。追加は合うグループへ 1 つずつ。
FORMULAE=""
# GNU userland: BSD 版コマンドを GNU 版へ置き換え
FORMULAE="$FORMULAE coreutils diffutils ed findutils gawk gnu-sed gnu-tar grep gzip"
# 基本ツール: shell / バージョン管理 / ダウンローダ
FORMULAE="$FORMULAE zsh git wget"
# 排他ロック: aws-login の多重ログイン防止用 (Linux は util-linux に同梱、macOS は未同梱)
FORMULAE="$FORMULAE flock"
# パッケージ / バージョンマネージャ
FORMULAE="$FORMULAE aqua"
# メディア
FORMULAE="$FORMULAE ffmpeg"
# aqua 補助: .pkg/.dmg 形式パッケージ(aws-cli 等)の展開に必要
FORMULAE="$FORMULAE unar"

# shellcheck disable=SC2086
for formula in $FORMULAE; do
	brew ls --versions "$formula" >/dev/null 2>&1 || brew install "$formula"
done

# GUI アプリ / フォント (cask)。ghostty: ターミナル, symbols-only-nerd-font: nvim のアイコン用。追加はここに 1 つずつ。
for cask in \
    ghostty font-symbols-only-nerd-font android-platform-tools
do
	brew ls --cask --versions "$cask" >/dev/null 2>&1 || brew install --cask "$cask"
done
{{- else -}}
# --- Linux: aqua prebuilt binary + ffmpeg static build ---
if ! command -v aqua >/dev/null 2>&1; then
	curl -fsSL -o /tmp/aqua.tar.gz https://github.com/aquaproj/aqua/releases/latest/download/aqua_linux_amd64.tar.gz
	tar xf /tmp/aqua.tar.gz -C /tmp aqua
	mv /tmp/aqua "$PREFIX/bin/aqua"
	chmod +x "$PREFIX/bin/aqua"
	rm -f /tmp/aqua.tar.gz
fi

if ! command -v ffmpeg >/dev/null 2>&1; then
	arch=linux64
	case "$(uname -m)" in aarch64|arm64) arch=linuxarm64 ;; esac
	curl -fsSL -o /tmp/ffmpeg.tar.xz "https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-${arch}-gpl.tar.xz"
	tar xf /tmp/ffmpeg.tar.xz -C /tmp
	find "/tmp/ffmpeg-master-latest-${arch}-gpl/bin" -type f -exec mv {} "$PREFIX/bin/" \;
	rm -rf /tmp/ffmpeg.tar.xz "/tmp/ffmpeg-master-latest-${arch}-gpl"
fi
{{- end }}
