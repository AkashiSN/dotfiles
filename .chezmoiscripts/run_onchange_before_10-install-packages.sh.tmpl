#!/bin/bash
# Provision package prerequisites that must exist before chezmoi applies files
# and before `aqua install` runs. Tools themselves are declared in aqua.yaml.
# run_onchange: 下のパッケージ一覧を書き換えると既存マシンでも再実行される（冪等）。
# bash 必須: 下のパッケージ一覧を配列で持つ（apt/dnf 系には bash が標準搭載）。
set -eu

printf '\n\033[1;36m==> %s\033[0m\n' "システムパッケージを準備中 (brew/apt・aqua・ffmpeg)"

PREFIX="$HOME/.local"
mkdir -p "$PREFIX/bin" "$PREFIX/lib"

{{ if eq .chezmoi.os "darwin" -}}
# --- macOS: Homebrew (GNU userland + a few system tools not in aqua) ---
if ! command -v brew >/dev/null 2>&1; then
	/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
BREW_PREFIX={{ if eq .chezmoi.arch "arm64" }}/opt/homebrew{{ else }}/usr/local{{ end }}
eval "$($BREW_PREFIX/bin/brew shellenv)"

# Homebrew formula（aqua に無いシステムツール / GNU userland）。
# 用途ごとにグループ分け。追加は合うグループへ 1 つずつ。
FORMULAE=(
	# GNU userland: BSD 版コマンドを GNU 版へ置き換え
	coreutils
	diffutils
	ed
	findutils
	gawk
	gnu-sed
	gnu-tar
	grep
	gzip
	# 基本ツール: shell / 端末多重化 / バージョン管理 / ダウンローダ
	zsh
	bash
	# tmux: 対話用の端末多重化 + vim-tmux-navigator 連携(libevent/ncurses 依存のため aqua でなく system 導入)
	tmux
	# abduco: ide(nvim)の SSH 切断耐性用セッション永続化。tmux と違い端末エミュレーションをしないため制御文字化け/フルスクリーン干渉が無い
	abduco
	git
	wget
	# 排他ロック: aws-login の多重ログイン防止用 (Linux は util-linux に同梱、macOS は未同梱)
	flock
	# agmsg: メッセージ DB 用 sqlite3 CLI (macOS は標準搭載するが依存として明示導入)
	sqlite
	# パッケージ / バージョンマネージャ
	aqua
	# aqua 補助: .pkg/.dmg 形式パッケージ(aws-cli 等)の展開に必要
	unar
	# メディア
	ffmpeg
)

for formula in "${FORMULAE[@]}"; do
	brew ls --versions "$formula" >/dev/null 2>&1 || brew install --yes "$formula"
done

# Homebrew cask（GUI アプリ / フォント）。
# 用途ごとにグループ分け。追加は合うグループへ 1 つずつ。
CASKS=(
	# ターミナル
	ghostty
	# フォント: symbols-only-nerd-font は nvim のアイコン用、plemol-jp は日本語表示用
	font-symbols-only-nerd-font
	font-plemol-jp
	# デバイス連携: adb / fastboot 等
	android-platform-tools
)

for cask in "${CASKS[@]}"; do
	brew ls --cask --versions "$cask" >/dev/null 2>&1 || brew install --yes --cask "$cask"
done
{{- else -}}
# --- Linux: system packages + aqua prebuilt binary + ffmpeg static build ---
# aqua/ffmpeg は単一バイナリで導入するが、それ以外はディストリのパッケージマネージャで入れる
# (GNU userland/flock/unar は標準搭載のため不要)。用途ごとにグループ分けし、追加は合うグループへ。
# apt(Debian/Ubuntu)と dnf(Fedora/AL2023 等)でパッケージ名が異なるため一覧を分けて持つ。

# apt 系パッケージ。用途ごとにグループ分け。追加は合うグループへ 1 つずつ。
APT_PACKAGES=(
	# 基本ツール: shell / 端末多重化 / バージョン管理
	# tmux: 対話用の端末多重化 + vim-tmux-navigator 連携
	# abduco: ide(nvim)の SSH 切断耐性用セッション永続化(端末エミュレーション無しで制御文字化け/フルスクリーン干渉が無い)
	zsh
	tmux
	abduco
	git
	# agmsg: メッセージ DB 用 sqlite3 CLI
	sqlite3
	# ビルド: nvim の tree-sitter パーサーをその場でビルドする C コンパイラ(cc)を提供
	build-essential
	# 展開: ffmpeg static build(.tar.xz)用 xz / zip 展開用 unzip
	xz-utils
	unzip
    zstd
	# サンドボックス: codex の bwrap 用 (aqua レジストリに無く Linux のみ導入)
	bubblewrap
)

# dnf 系パッケージ。グループは apt 側と対応。名前が異なるものだけ差し替える。
DNF_PACKAGES=(
	# 基本ツール: shell / 端末多重化 / バージョン管理
	# abduco: ide(nvim)の SSH 切断耐性用セッション永続化(Fedora は標準、AL2023 等では EPEL が要る場合あり)
	zsh
	tmux
	abduco
	git
	# agmsg: メッセージ DB 用 sqlite3 CLI (sqlite パッケージが sqlite3 バイナリを提供)
	sqlite
	# ビルド: tree-sitter パーサー用 C コンパイラ(cc)。dnf は gcc が cc を提供
	gcc
	make
	# 展開: ffmpeg static build(.tar.xz)用 xz / zip 展開用 unzip
	xz
	unzip
    zstd
	# サンドボックス: codex の bwrap 用
	bubblewrap
)

if command -v apt-get >/dev/null 2>&1; then
	sudo apt-get update
	sudo apt-get install -y "${APT_PACKAGES[@]}"
elif command -v dnf >/dev/null 2>&1; then
	sudo dnf install -y "${DNF_PACKAGES[@]}"
fi

if ! command -v aqua >/dev/null 2>&1; then
	curl -fsSL -o /tmp/aqua.tar.gz https://github.com/aquaproj/aqua/releases/latest/download/aqua_linux_amd64.tar.gz
	tar xf /tmp/aqua.tar.gz -C /tmp aqua
	mv /tmp/aqua "$PREFIX/bin/aqua"
	chmod +x "$PREFIX/bin/aqua"
	rm -f /tmp/aqua.tar.gz
fi

if ! command -v ffmpeg >/dev/null 2>&1; then
	arch=linux64
	case "$(uname -m)" in aarch64|arm64) arch=linuxarm64 ;; esac
	curl -fsSL -o /tmp/ffmpeg.tar.xz "https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-${arch}-gpl.tar.xz"
	tar xf /tmp/ffmpeg.tar.xz -C /tmp
	find "/tmp/ffmpeg-master-latest-${arch}-gpl/bin" -type f -exec mv {} "$PREFIX/bin/" \;
	rm -rf /tmp/ffmpeg.tar.xz "/tmp/ffmpeg-master-latest-${arch}-gpl"
fi
{{- end }}
