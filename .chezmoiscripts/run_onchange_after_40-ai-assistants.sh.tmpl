#!/bin/sh
# Install AI coding assistant CLIs via their official native installers.
# どちらも ~/.local/bin にネイティブバイナリを置き、以後は本体が自動更新する
# （aqua 管理外。バージョンは下の変数で固定/追従を切り替える）。
# run_onchange: 下のチャネル/バージョンを書き換えると既存マシンでも再実行される。
set -eu

export PATH="$HOME/.local/bin:$PATH"

# --- Claude Code (claude.ai/install.sh) ---
# stable / latest / 固定バージョン(例: 2.1.179)。
CLAUDE_CHANNEL="latest"
curl -fsSL https://claude.ai/install.sh | bash -s "$CLAUDE_CHANNEL"

# --- OpenAI Codex (chatgpt.com/codex/install.sh) ---
# latest / 固定バージョン(例: 0.140.0)。CODEX_RELEASE で指定、非対話で導入。
CODEX_RELEASE="latest"
curl -fsSL https://chatgpt.com/codex/install.sh | \
	CODEX_RELEASE="$CODEX_RELEASE" CODEX_NON_INTERACTIVE=1 sh

# --- agmsg (github.com/fujibee/agmsg) ---
# claude と codex が同一プロジェクト内でメッセージをやり取りし相互レビューできる
# ようにするツール(nvim IDE モードの codex/claude ペイン運用が前提)。
# agmsg は ~/.agents/skills, ~/.claude/commands, ~/.codex/config.toml を書き換える
# ため、claude/codex を入れた後(=このスクリプトの末尾)に導入する。
# 本体を更新/固定したいときは AGMSG_REF を書き換える(run_onchange が再実行される)。
AGMSG_REF="main"
AGMSG_SRC="$HOME/.local/share/agmsg-src"
AGMSG_SKILL="$HOME/.agents/skills/agmsg"
# sqlite3(メッセージ DB)と git が無い環境では apply を止めずスキップする。
if command -v sqlite3 >/dev/null 2>&1 && command -v git >/dev/null 2>&1; then
	if [ -d "$AGMSG_SRC/.git" ]; then
		git -C "$AGMSG_SRC" fetch --quiet origin "$AGMSG_REF"
		git -C "$AGMSG_SRC" checkout --quiet "$AGMSG_REF"
		git -C "$AGMSG_SRC" merge --ff-only --quiet "origin/$AGMSG_REF"
	else
		git clone --quiet --branch "$AGMSG_REF" https://github.com/fujibee/agmsg.git "$AGMSG_SRC" \
			|| git clone --quiet https://github.com/fujibee/agmsg.git "$AGMSG_SRC"
	fi
	# install.sh は非対話 --cmd agmsg。既存導入は --update で DB/teams を保持して更新。
	if [ -d "$AGMSG_SKILL" ]; then
		(cd "$AGMSG_SRC" && ./install.sh --cmd agmsg --update)
	else
		(cd "$AGMSG_SRC" && ./install.sh --cmd agmsg)
	fi
else
	echo "agmsg: sqlite3 / git が無いためスキップしました" >&2
fi
