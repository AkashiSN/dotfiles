#!/bin/sh
# Install AI coding assistant CLIs via their official native installers.
# どちらも ~/.local/bin にネイティブバイナリを置き、以後は本体が自動更新する
# （aqua 管理外。バージョンは下の変数で固定/追従を切り替える）。
# run_onchange: 下のチャネル/バージョンを書き換えると既存マシンでも再実行される。
set -eu

{{ template "shell-log" }}
step "AI アシスタント CLI(claude/codex/ollama/agmsg/codegraph)をインストール中"

export PATH="$HOME/.local/bin:$PATH"

# --- Claude Code (claude.ai/install.sh) ---
# stable / latest / 固定バージョン(例: 2.1.179)。
CLAUDE_CHANNEL="latest"
curl -fsSL https://claude.ai/install.sh | bash -s "$CLAUDE_CHANNEL"

# --- OpenAI Codex (chatgpt.com/codex/install.sh) ---
# latest / 固定バージョン(例: 0.140.0)。CODEX_RELEASE で指定、非対話で導入。
CODEX_RELEASE="latest"
curl -fsSL https://chatgpt.com/codex/install.sh | \
	CODEX_RELEASE="$CODEX_RELEASE" CODEX_NON_INTERACTIVE=1 sh

# --- Ollama (ollama.com) ---
# ローカルで LLM を動かすランタイム(クラウド API ではなくオフライン実行)。
# install.sh は Darwin/Linux 両対応で非対話導入する: macOS は Ollama.app を
# /Applications に置いて /usr/local/bin/ollama へシンボリックリンク(PATH 追加時に
# sudo パスワードを要求することがある)、Linux は /usr/local/bin へバイナリを入れる。
# 以後は本体が自己更新する(aqua 管理外)。
curl -fsSL https://ollama.com/install.sh | sh

# --- agmsg (github.com/fujibee/agmsg) ---
# claude と codex が同一プロジェクト内でメッセージをやり取りし相互レビューできるようにするツール。
# claude/codex の設定(~/.agents/skills, ~/.claude/commands, ~/.codex/config.toml)を
# 書き換えるため、両者を入れた後(=このスクリプトの末尾)に導入する。
# setup.sh は temp に main を clone → install.sh "$@" 実行 → temp 破棄する
# ブートストラップで、引数を install.sh に転送する(claude/codex と同じ curl ワンライナー)。
# 再インストール/更新を強制したいときは次のマーカーを書き換える(内容変更で再実行)。
# agmsg-reinstall-marker: 2026-06-19
# メッセージ DB 用の sqlite3 は before_10(パッケージ前提)で導入済み。
# Codex monitor モード(beta): install.sh が ~/.codex/config.toml の writable_roots に
# db/teams/run を追記する。run は monitor のブリッジ用で、シムは ~/.agents/bin/codex に置かれ、
# 10-path.zsh で PATH 前段に入れている。
# 実際の有効化はプロジェクトごとに手動(/agmsg mode monitor)。
# 詳細: docs/agmsg-cheatsheet.md の「Codex monitor モード」節。
if [ -d "$HOME/.agents/skills/agmsg" ]; then
	curl -fsSL https://raw.githubusercontent.com/fujibee/agmsg/main/setup.sh | bash -s -- --cmd agmsg --update
else
	curl -fsSL https://raw.githubusercontent.com/fujibee/agmsg/main/setup.sh | bash -s -- --cmd agmsg
fi

# --- CodeGraph (github.com/colbymchenry/codegraph) ---
# コードベースの事前インデックス(知識グラフ)を MCP 経由でエージェントに渡し、
# ツール呼び出し回数とコストを削減するセマンティックコード解析ツール。
# install.sh が自前ランタイム同梱のバイナリを PATH(~/.local/bin)へ置き(Node 不要)、
# 以後は本体が `codegraph upgrade` で自己更新する(aqua 管理外)。
# 続く `codegraph install --yes` が claude/codex を自動検出して MCP 設定・権限・
# 指示ファイルへの追記を非対話(グローバル)で実施するため、両者を入れた後に導入する。
# プロジェクト単位のインデックスは各リポジトリで `codegraph init` を別途実行する。
# 再インストール/更新を強制したいときは次のマーカーを書き換える(内容変更で再実行)。
# codegraph-reinstall-marker: 2026-06-18
curl -fsSL https://raw.githubusercontent.com/colbymchenry/codegraph/main/install.sh | sh
codegraph install --yes
codegraph telemetry off
