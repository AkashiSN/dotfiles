#!/bin/sh
# Install AI coding assistant CLIs via their official native installers.
# どちらも ~/.local/bin にネイティブバイナリを置き、以後は本体が自動更新する
# （aqua 管理外。バージョンは下の変数で固定/追従を切り替える）。
# run_onchange: 下のチャネル/バージョンを書き換えると既存マシンでも再実行される。
set -eu

export PATH="$HOME/.local/bin:$PATH"

# --- Claude Code (claude.ai/install.sh) ---
# stable / latest / 固定バージョン(例: 2.1.179)。
CLAUDE_CHANNEL="latest"
curl -fsSL https://claude.ai/install.sh | bash -s "$CLAUDE_CHANNEL"

# --- OpenAI Codex (chatgpt.com/codex/install.sh) ---
# latest / 固定バージョン(例: 0.140.0)。CODEX_RELEASE で指定、非対話で導入。
CODEX_RELEASE="latest"
curl -fsSL https://chatgpt.com/codex/install.sh | \
	CODEX_RELEASE="$CODEX_RELEASE" CODEX_NON_INTERACTIVE=1 sh

# --- agmsg (github.com/fujibee/agmsg) ---
# claude と codex が同一プロジェクト内でメッセージをやり取りし相互レビューできる
# ようにするツール(nvim IDE モードの codex/claude ペイン運用が前提)。
# claude/codex の設定(~/.agents/skills, ~/.claude/commands, ~/.codex/config.toml)を
# 書き換えるため、両者を入れた後(=このスクリプトの末尾)に導入する。
# setup.sh は temp に main を clone → install.sh "$@" 実行 → temp 破棄する
# ブートストラップで、引数を install.sh に転送する(claude/codex と同じ curl ワンライナー)。
# 既存導入は --update で DB/teams を保持して更新、無ければ --cmd agmsg で新規。
# 再インストール/更新を強制したいときは次のマーカーを書き換える(内容変更で再実行)。
# agmsg-reinstall-marker: 2026-06-18
# sqlite3(メッセージ DB)と git(setup.sh の clone)が無い環境では apply を止めずスキップ。
if command -v sqlite3 >/dev/null 2>&1 && command -v git >/dev/null 2>&1; then
	if [ -d "$HOME/.agents/skills/agmsg" ]; then
		curl -fsSL https://raw.githubusercontent.com/fujibee/agmsg/main/setup.sh | bash -s -- --cmd agmsg --update
	else
		curl -fsSL https://raw.githubusercontent.com/fujibee/agmsg/main/setup.sh | bash -s -- --cmd agmsg
	fi
else
	echo "agmsg: sqlite3 / git が無いためスキップしました" >&2
fi
