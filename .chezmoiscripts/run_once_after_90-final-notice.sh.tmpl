#!/bin/sh
# 初回 apply 後に必要な手動ステップ（direnv allow / shell 変更など）を案内する。
# run_once: 一度だけ実行＝この案内は初回セットアップ時のみ表示される
# （文言を書き換えれば再表示される）。副作用は無く「表示のみ」にすること。
set -eu

printf '\n\033[1;33m==> %s\033[0m\n' "セットアップ完了。残りの手動ステップ:"

# ログインシェルが zsh でなければ変更を促す（既に zsh なら出さない）。
if [ "$(basename "${SHELL:-}")" != "zsh" ]; then
	printf '  \033[1m%s\033[0m\n' "ログインシェルを zsh に変更:"
	printf '    sudo usermod -s "$(command -v zsh)" "$(id -un)"\n'
fi

# ホーム直下の .envrc（use flake）を direnv に許可させる。
printf '  \033[1m%s\033[0m\n' "ホームの .envrc を direnv に許可:"
printf '    direnv allow ~\n'
